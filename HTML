<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Birthday Journey for FAA</title>
    <style>
        body { background: #0f172a; color: #f8fafc; font-family: sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; text-align: center; }
        .step { display: none; width: 90%; max-width: 400px; animation: fadeIn 0.5s; }
        .active { display: block; }
        .btn-container { margin-top: 20px; }
        button { background: #f472b6; border: none; padding: 10px 25px; border-radius: 20px; color: white; cursor: pointer; font-weight: bold; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

    <!-- Step 1: Countdown -->
    <div id="step1" class="step active">
        <h1>ALMOST THERE!</h1>
        <div id="timer" style="font-size: 2rem; margin: 20px 0;">00:09:07:24</div>
        <button onclick="nextStep(1)">Skip countdown ></button>
    </div>

    <!-- Step 2: Mesej Utama -->
    <div id="step2" class="step">
        <h1>Happy Birthday, FAA!</h1>
        <p>Turning 17!</p>
        <div class="btn-container">
            <button onclick="nextStep(2)">Next ></button>
        </div>
    </div>

    <!-- Step 3: Mesej Cinta -->
    <div id="step3" class="step">
        <h2>A Message for You</h2>
        <p style="padding: 20px; background: #1e293b; border-radius: 15px;">
            "Terima kasih sebab sentiasa ada dengan Yun. Yun tahu Yun tak perfect, tapi Yun akan sentiasa cuba yang terbaik untuk baby."
        </p>
        <button onclick="nextStep(3)">Unlock my gift ></button>
    </div>

    <audio id="bgMusic" loop>
        <source src="JVKE, ZVC - made for me (official lyric video) [OVlxbGND20A].mp3" type="audio/mp3">
    </audio>

    <script>
        function nextStep(current) {
            document.getElementById('step' + current).classList.remove('active');
            document.getElementById('step' + (current + 1)).classList.add('active');
            document.getElementById('bgMusic').play(); // Muzik start bila tekan next
        }
    </script>
</body>
</html>
